[Unit]
Description=Panjur shutter control
After=network-online.target
Wants=network-online.target

[Service]
User=hidayeteren
WorkingDirectory=/home/hidayeteren/panjur
ExecStart=/home/hidayeteren/panjur-env/bin/gunicorn --workers 1 --threads 8 --bind 0.0.0.0:8000 --access-logfile - --error-logfile - app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
